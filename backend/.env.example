CHIRON_LLM_MODE=gemini
CHIRON_GEMINI_API_KEY=replace_me
CHIRON_GEMINI_MODEL=gemini-3-flash-preview

# Optional per-step overrides. Leave unset to inherit CHIRON_GEMINI_MODEL.
# CHIRON_GEMINI_QUERY_MODEL=gemini-3-flash-preview
# CHIRON_GEMINI_SYNTHESIS_MODEL=gemini-3-flash-preview
# CHIRON_GEMINI_VERIFIER_MODEL=gemini-3-flash-preview

CHIRON_LITERATURE_CONNECTOR_MODE=pubmed
CHIRON_TRIALS_CONNECTOR_MODE=clinicaltrials
CHIRON_DRUG_SAFETY_CONNECTOR_MODE=dailymed
CHIRON_GUIDELINE_CONNECTOR_MODE=fixture

# Optional PubMed tuning.
# CHIRON_PUBMED_API_KEY=replace_me
